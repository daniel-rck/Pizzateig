{
  "name": "pizzateig",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Pizzateig-Rechner: exakte Zutatenmengen nach Bäcker-Prozent mit Hefe-Vorschlag nach Gehzeit und Temperatur. Offline-fähige PWA, lokal-first.",
  "keywords": [
    "pwa",
    "privacy",
    "offline",
    "react",
    "vite",
    "typescript",
    "pizza",
    "dough"
  ],
  "author": "daniel-rck",
  "license": "MIT",
  "homepage": "https://pizzateig.daniel-rck.workers.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/daniel-rck/pizzateig.git"
  },
  "bugs": {
    "url": "https://github.com/daniel-rck/pizzateig/issues"
  },
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "lucide-react": "^1.16.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cloudflare/workers-types": "^4.20260504.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6",
    "@vitest/ui": "^4.1.5",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "vite": "^8",
    "vite-plugin-pwa": "^1.3",
    "vitest": "^4.1.5",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.1",
    "workbox-window": "^7.4.0",
    "wrangler": "^4.87.0"
  },
  "webBase": {
    "version": "0.2.1"
  }
}
